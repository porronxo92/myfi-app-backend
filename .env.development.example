# ============================================
# DEVELOPMENT ENVIRONMENT CONFIGURATION
# ============================================
# Copiar este archivo a .env para desarrollo local
# cp .env.development.example .env

# ============================================
# ENVIRONMENT
# ============================================
ENVIRONMENT=development

# ============================================
# ENVIRONMENT-SPECIFIC URLS
# ============================================
FRONTEND_URL=http://localhost:4200
BACKEND_URL=http://localhost:8000
ALLOWED_HOSTS=localhost,127.0.0.1

# ============================================
# SECURITY & JWT
# ============================================
# ⚠️ Generar claves seguras con: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=your-secret-key-here-change-me
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# Refresh Tokens
REFRESH_TOKEN_SECRET_KEY=your-refresh-secret-key-here-change-me
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================
# ENCRYPTION - PSD2 COMPLIANCE
# ============================================
# ⚠️ CRÍTICO: Clave maestra para encriptación AES-256-GCM de datos sensibles
# Generar con: python -c "import os, base64; print(base64.b64encode(os.urandom(32)).decode())"
# ⚠️ NUNCA compartir esta clave ni commitearla en git
# ⚠️ Mantener backup seguro offline de esta clave
ENCRYPTION_MASTER_KEY=your-encryption-key-here-change-me

# Versión de la clave de encriptación (para rotación de claves)
ENCRYPTION_KEY_VERSION=1

# ============================================
# DATABASE
# ============================================
# DEV usa la base de datos compartida de Neon (mismo que PRE)
DATABASE_URL_LOCALHOST=postgresql://neondb_owner:npg_6kU1KjbCclpY@ep-jolly-river-a93ithgb.gwc.azure.neon.tech/neondb
DATABASE_URL_PRE=postgresql://neondb_owner:npg_6kU1KjbCclpY@ep-jolly-river-a93ithgb.gwc.azure.neon.tech/neondb
DATABASE_URL_PROD=postgresql://neondb_owner:npg_6kU1KjbCclpY@ep-jolly-river-a93ithgb.gwc.azure.neon.tech/neondb
DB_POOL_SIZE=5
DB_POOL_OVERFLOW=10

# ============================================
# LLM CONFIGURATION
# ============================================
# IMPORTANTE: Solicita una nueva API Key en https://ai.google.dev/
GEMINI_API_KEY=your-gemini-api-key-here
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.0-flash

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=DEBUG
LOGS_DIR=../logsBackend
LOG_ROTATION_SIZE_MB=10
LOG_BACKUP_COUNT=5

# ============================================
# FILE UPLOAD
# ============================================
MAX_FILE_SIZE_MB=10
ALLOWED_EXTENSIONS=pdf,xlsx,csv,txt

# ============================================
# CORS
# ============================================
CORS_ORIGINS=http://localhost:4200,http://localhost:3000,http://127.0.0.1:5173
CORS_MAX_AGE=3600

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Login-specific rate limiting (más restrictivo)
LOGIN_RATE_LIMIT_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_MINUTES=15

# ============================================
# STOCK MARKET APIs - FINNHUB + ALPHA VANTAGE FALLBACK
# ============================================

# Finnhub API (Prioridad 1 - 60 llamadas/minuto)
# Obtén tu API key gratis en: https://finnhub.io/
FINNHUB_API_KEY=your-finnhub-api-key-here
FINNHUB_MAX_CALLS_PER_MINUTE=60

# Alpha Vantage API (Fallback - 25 llamadas/día)
# Obtén tu API key gratis en: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-api-key-here
ALPHA_VANTAGE_BASE_URL=https://www.alphavantage.co/query
ALPHA_VANTAGE_MAX_CALLS_PER_DAY=25

# Brandfetch API (Stock Logos)
# Obtén tu Client ID en: https://brandfetch.com/
BRANDFETCH_CLIENT_ID=your-brandfetch-client-id-here
