# ============================================
# PRE-PRODUCTION ENVIRONMENT CONFIGURATION
# ============================================
# Configuración para el entorno PRE (Render + Netlify)
# Configurar estas variables en Render Dashboard → Environment Variables

# ============================================
# ENVIRONMENT
# ============================================
ENVIRONMENT=pre

# ============================================
# ENVIRONMENT-SPECIFIC URLS
# ============================================
FRONTEND_URL=https://myfi-front.netlify.app
BACKEND_URL=https://myfi-app-backend.onrender.com
ALLOWED_HOSTS=myfi-app-backend.onrender.com

# ============================================
# SECURITY & JWT
# ============================================
# ⚠️ CRÍTICO: Usar claves diferentes a desarrollo
# ⚠️ Generar claves seguras con: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=<GENERATE_NEW_SECRET_KEY>
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# Refresh Tokens
REFRESH_TOKEN_SECRET_KEY=<GENERATE_NEW_REFRESH_SECRET_KEY>
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================
# ENCRYPTION - PSD2 COMPLIANCE
# ============================================
# ⚠️ CRÍTICO: Clave maestra para encriptación AES-256-GCM de datos sensibles
# ⚠️ Generar con: python -c "import os, base64; print(base64.b64encode(os.urandom(32)).decode())"
# ⚠️ Usar la MISMA clave que desarrollo si compartes datos, o nueva si es entorno aislado
ENCRYPTION_MASTER_KEY=<GENERATE_NEW_ENCRYPTION_KEY>

# Versión de la clave de encriptación (para rotación de claves)
ENCRYPTION_KEY_VERSION=1

# ============================================
# DATABASE
# ============================================
# PRE usa la misma base de datos que DEV (Neon compartida)
# Si quieres aislar datos, crea una base de datos separada en Neon
DATABASE_URL_LOCALHOST=postgresql://neondb_owner:npg_6kU1KjbCclpY@ep-jolly-river-a93ithgb.gwc.azure.neon.tech/neondb
DATABASE_URL_PRE=postgresql://neondb_owner:npg_6kU1KjbCclpY@ep-jolly-river-a93ithgb.gwc.azure.neon.tech/neondb
DATABASE_URL_PROD=postgresql://neondb_owner:npg_6kU1KjbCclpY@ep-jolly-river-a93ithgb.gwc.azure.neon.tech/neondb
DB_POOL_SIZE=10
DB_POOL_OVERFLOW=20

# ============================================
# LLM CONFIGURATION
# ============================================
# Puede ser la misma API key que desarrollo (según decisión del equipo)
GEMINI_API_KEY=<YOUR_GEMINI_API_KEY>
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.0-flash

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=INFO
LOGS_DIR=../logsBackend
LOG_ROTATION_SIZE_MB=10
LOG_BACKUP_COUNT=5

# ============================================
# FILE UPLOAD
# ============================================
MAX_FILE_SIZE_MB=10
ALLOWED_EXTENSIONS=pdf,xlsx,csv,txt

# ============================================
# CORS
# ============================================
# Solo permitir el frontend de Netlify en PRE
CORS_ORIGINS=https://myfi-front.netlify.app
CORS_MAX_AGE=3600

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Login-specific rate limiting (más restrictivo)
LOGIN_RATE_LIMIT_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_MINUTES=15

# ============================================
# STOCK MARKET APIs - FINNHUB + ALPHA VANTAGE FALLBACK
# ============================================

# Finnhub API (Prioridad 1 - 60 llamadas/minuto)
# Puede ser la misma API key que desarrollo (según decisión del equipo)
FINNHUB_API_KEY=<YOUR_FINNHUB_API_KEY>
FINNHUB_MAX_CALLS_PER_MINUTE=60

# Alpha Vantage API (Fallback - 25 llamadas/día)
ALPHA_VANTAGE_API_KEY=<YOUR_ALPHA_VANTAGE_API_KEY>
ALPHA_VANTAGE_BASE_URL=https://www.alphavantage.co/query
ALPHA_VANTAGE_MAX_CALLS_PER_DAY=25

# Brandfetch API (Stock Logos)
BRANDFETCH_CLIENT_ID=<YOUR_BRANDFETCH_CLIENT_ID>
