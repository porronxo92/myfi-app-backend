# ============================================
# PRODUCTION ENVIRONMENT CONFIGURATION (GCP Cloud Run)
# ============================================
# Configuración para el entorno PRODUCCIÓN en GCP Cloud Run
# ⚠️ NO usar variables de entorno directamente - usar GCP Secret Manager
# ⚠️ Este archivo es solo referencia de las variables necesarias

# ============================================
# ENVIRONMENT
# ============================================
ENVIRONMENT=production

# ============================================
# ENVIRONMENT-SPECIFIC URLS
# ============================================
# 🔧 TBD: Actualizar con las URLs reales de Cloud Run
FRONTEND_URL=<TBD_CLOUD_RUN_FRONTEND_URL_OR_CUSTOM_DOMAIN>
BACKEND_URL=<TBD_CLOUD_RUN_BACKEND_URL>
ALLOWED_HOSTS=<TBD_CLOUD_RUN_SERVICE_URL>

# Ejemplo con custom domain:
# FRONTEND_URL=https://myfi.yourdomain.com
# BACKEND_URL=https://api.myfi.yourdomain.com
# ALLOWED_HOSTS=api.myfi.yourdomain.com

# ============================================
# SECURITY & JWT
# ============================================
# ⚠️ CRÍTICO: Almacenar en GCP Secret Manager, NO en variables de entorno
# Crear secrets con: gcloud secrets create jwt-secret-key --data-file=-
# Mapear en Cloud Run deployment con: --set-secrets="JWT_SECRET_KEY=jwt-secret-key:latest"
JWT_SECRET_KEY=<STORED_IN_GCP_SECRET_MANAGER>
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# Refresh Tokens
REFRESH_TOKEN_SECRET_KEY=<STORED_IN_GCP_SECRET_MANAGER>
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================
# ENCRYPTION - PSD2 COMPLIANCE
# ============================================
# ⚠️ CRÍTICO: Almacenar en GCP Secret Manager
# ⚠️ Hacer backup seguro offline de esta clave
ENCRYPTION_MASTER_KEY=<STORED_IN_GCP_SECRET_MANAGER>
ENCRYPTION_KEY_VERSION=1

# ============================================
# DATABASE
# ============================================
# 🔧 OPCIÓN A: Cloud SQL PostgreSQL (recomendado)
# DATABASE_URL_PROD=postgresql://user:password@/dbname?host=/cloudsql/PROJECT:REGION:INSTANCE
# Usar Cloud SQL Connector para conexión segura sin contraseñas

# 🔧 OPCIÓN B: Seguir usando Neon PostgreSQL
# DATABASE_URL_PROD=postgresql://neondb_owner:password@ep-xxx.gwc.azure.neon.tech/neondb

DATABASE_URL_LOCALHOST=<NOT_USED_IN_PRODUCTION>
DATABASE_URL_PRE=<NOT_USED_IN_PRODUCTION>
DATABASE_URL_PROD=<TBD_CLOUD_SQL_OR_NEON_CONNECTION_STRING>
DB_POOL_SIZE=20
DB_POOL_OVERFLOW=40

# ============================================
# LLM CONFIGURATION
# ============================================
# ⚠️ Almacenar en GCP Secret Manager
GEMINI_API_KEY=<STORED_IN_GCP_SECRET_MANAGER>
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.0-flash

# ============================================
# LOGGING
# ============================================
# Cloud Run automáticamente envía logs a Cloud Logging
LOG_LEVEL=INFO
LOGS_DIR=/tmp/logs
LOG_ROTATION_SIZE_MB=10
LOG_BACKUP_COUNT=5

# ============================================
# FILE UPLOAD
# ============================================
MAX_FILE_SIZE_MB=10
ALLOWED_EXTENSIONS=pdf,xlsx,csv,txt

# ============================================
# CORS
# ============================================
# Solo permitir el frontend de producción
CORS_ORIGINS=<TBD_PRODUCTION_FRONTEND_URL>
CORS_MAX_AGE=86400

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_REQUESTS=200
RATE_LIMIT_WINDOW=60

# Login-specific rate limiting (más restrictivo)
LOGIN_RATE_LIMIT_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_MINUTES=15

# ============================================
# STOCK MARKET APIs
# ============================================
# ⚠️ Considerar almacenar en GCP Secret Manager

# Finnhub API
FINNHUB_API_KEY=<STORED_IN_GCP_SECRET_MANAGER>
FINNHUB_MAX_CALLS_PER_MINUTE=60

# Alpha Vantage API
ALPHA_VANTAGE_API_KEY=<STORED_IN_GCP_SECRET_MANAGER>
ALPHA_VANTAGE_BASE_URL=https://www.alphavantage.co/query
ALPHA_VANTAGE_MAX_CALLS_PER_DAY=25

# Brandfetch API
BRANDFETCH_CLIENT_ID=<STORED_IN_GCP_SECRET_MANAGER>

# ============================================
# GCP SPECIFIC CONFIGURATION
# ============================================
# Configuración específica de Cloud Run (si es necesaria)

# PORT es configurado automáticamente por Cloud Run (default: 8080)
# No es necesario especificarlo aquí

# PROJECT_ID (si necesitas hacer llamadas a otros servicios GCP)
# GCP_PROJECT_ID=your-project-id

# REGION (si necesitas especificar región)
# GCP_REGION=europe-west1
